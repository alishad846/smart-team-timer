    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "electron:dev": "electron electron/main.js",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "get-windows": "^9.2.3",
    "lucide-react": "^0.454.0",
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "screenshot-desktop": "^1.15.0",
    "ws": "^8.18.3",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.18.0",
    "postcss": "^8.5.1",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "iohook": "^0.9.6"
  },
  "build": {
    "appId": "com.smartteamtimer.app",
    "directories": {
